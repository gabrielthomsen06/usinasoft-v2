{$DOMAIN}, www.{$DOMAIN} {
    # HTTPS automático via Let's Encrypt
    tls {$SSL_EMAIL}

    # Redireciona www → apex
    @www host www.{$DOMAIN}
    redir @www https://{$DOMAIN}{uri} permanent

    # Frontend (SPA)
    handle {
        reverse_proxy frontend:80
    }

    # Compressão
    encode gzip zstd

    # Logs
    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
